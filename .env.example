# ── LLM provider keys (set ONE; if both are set, GEMINI wins by default) ──
#
# Option 1: Google Gemini  (gemini-flash-latest)
# Free tier at https://aistudio.google.com/app/apikey — no credit card.
# Generous quota: 15 RPM, ~1M tokens/day on Free.
GEMINI_API_KEY=your-gemini-key-here

# Option 2: Groq            (llama-3.3-70b-versatile)
# Free key at https://console.groq.com/keys — no credit card.
# 30 RPM on Free, very fast (sub-2-second completions).
GROQ_API_KEY=your-groq-key-here

# Optional explicit override. If both keys are set, this picks one.
# Values: "gemini" | "groq". Unset = auto (prefers Gemini if available).
# LLM_PROVIDER=gemini

# Basic-auth credentials enforced by middleware.js.
# If either is unset, auth is DISABLED (open access — useful for local dev).
# Set both to require login on every route (recommended on the deployed app).
AUTH_USERNAME=your-username
AUTH_PASSWORD=your-password
