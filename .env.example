# Groq API key for the JD-tailoring backend (/api/tailor).
# Get a free key at https://console.groq.com/keys — no credit card required.
# Free tier: ~30 requests/min on llama-3.3-70b-versatile, plenty for this app.
# Do NOT commit your real key.
GROQ_API_KEY=your-key-here

# Basic-auth credentials enforced by middleware.js.
# If either is unset, auth is DISABLED (open access — useful for local dev).
# Set both to require login on every route (recommended on the deployed app).
AUTH_USERNAME=your-username
AUTH_PASSWORD=your-password
